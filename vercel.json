{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node obfuscate.js",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1.html" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/lost.html" }
  ]
}